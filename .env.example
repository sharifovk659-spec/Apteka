APP_NAME=Salomat
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/salomat/public

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=salomat
DB_USERNAME=your_mysql_user
DB_PASSWORD=

STORE_NAME=Salomat
STORE_EMAIL=info@example.com
STORE_PHONE="+992 00 000 00 00"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="info@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Production Hostinger: copy .env.production.example → server .env
# APP_URL=https://apteka.inovaauto.com
