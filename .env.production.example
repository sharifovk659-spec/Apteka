APP_NAME=Salomat
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://apteka.inovaauto.com

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=CHANGE_ME_DATABASE
DB_USERNAME=CHANGE_ME_USER
DB_PASSWORD=CHANGE_ME_PASSWORD

STORE_NAME=Salomat
STORE_EMAIL=info@inovaauto.com
STORE_PHONE="+992 00 000 00 00"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.inovaauto.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="info@inovaauto.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
